@model MiniJira.Models.Proyecto
@{
    ViewData["Title"] = "Eliminar Proyecto";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación</h4>
            </div>
            <div class="card-body p-4">
                <p class="lead">¿Estás seguro que deseas eliminar el siguiente proyecto?</p>
                <div class="alert alert-warning">
                    <strong>@Model.Nombre</strong>
                    @if (Model.Tareas.Any())
                    {
                        <br />
                        <small>⚠️ Este proyecto contiene <strong>@Model.Tareas.Count tarea(s)</strong> que también serán eliminadas.</small>
                    }
                </div>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash me-1"></i>Sí, Eliminar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
