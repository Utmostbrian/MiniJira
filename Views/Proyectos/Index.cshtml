@model IEnumerable<MiniJira.Models.Proyecto>
@{
    ViewData["Title"] = "Proyectos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-kanban-fill text-primary me-2"></i>Proyectos</h2>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Nuevo Proyecto
        </a>
    }
</div>

@if (TempData["Exito"] is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox display-3 d-block mb-3"></i>
        <p class="lead">No hay proyectos aún. ¡Crea el primero!</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var proyecto in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title fw-semibold mb-0">@proyecto.Nombre</h5>
                            @{
                                var badgeColor = proyecto.Estado switch
                                {
                                    MiniJira.Models.EstadoProyecto.Activo => "success",
                                    MiniJira.Models.EstadoProyecto.Pausado => "warning",
                                    MiniJira.Models.EstadoProyecto.Completado => "secondary",
                                    _ => "secondary"
                                };
                            }
                            <span class="badge bg-@badgeColor">@proyecto.Estado</span>
                        </div>
                        <p class="card-text text-muted small">
                            @(proyecto.Descripcion ?? "Sin descripción.")
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center">
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>@proyecto.FechaCreacion.ToString("dd/MM/yyyy")
                        </small>
                        <div class="btn-group btn-group-sm">
                            <a asp-action="Details" asp-route-id="@proyecto.Id"
                               class="btn btn-outline-primary">Ver</a>
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a asp-action="Edit" asp-route-id="@proyecto.Id"
                                   class="btn btn-outline-secondary">Editar</a>
                                <a asp-action="Delete" asp-route-id="@proyecto.Id"
                                   class="btn btn-outline-danger">Borrar</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
