@model MiniJira.Models.Proyecto
@{
    ViewData["Title"] = Model.Nombre;
}

@if (TempData["Exito"] is not null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Exito"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a asp-action="Index" class="text-muted text-decoration-none small">
            <i class="bi bi-arrow-left me-1"></i>Volver a Proyectos
        </a>
        <h2 class="fw-bold mt-1">@Model.Nombre</h2>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="btn-group">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-pencil me-1"></i>Editar
            </a>
            <a asp-controller="Tareas" asp-action="Create" asp-route-proyectoId="@Model.Id"
               class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle me-1"></i>Nueva Tarea
            </a>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted text-uppercase fw-semibold mb-3">Información</h6>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Estado</dt>
                    <dd class="col-sm-7">
                        @{
                            var color = Model.Estado switch
                            {
                                MiniJira.Models.EstadoProyecto.Activo => "success",
                                MiniJira.Models.EstadoProyecto.Pausado => "warning",
                                _ => "secondary"
                            };
                        }
                        <span class="badge bg-@color">@Model.Estado</span>
                    </dd>
                    <dt class="col-sm-5">Creado</dt>
                    <dd class="col-sm-7">@Model.FechaCreacion.ToString("dd/MM/yyyy")</dd>
                    <dt class="col-sm-5">Tareas</dt>
                    <dd class="col-sm-7">@Model.Tareas.Count total</dd>
                </dl>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.Descripcion))
        {
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <h6 class="text-muted text-uppercase fw-semibold mb-2">Descripción</h6>
                    <p class="mb-0">@Model.Descripcion</p>
                </div>
            </div>
        }
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-semibold">
                    <i class="bi bi-list-task me-1"></i>Tareas (@Model.Tareas.Count)
                </h6>
            </div>
            <div class="card-body p-0">
                @if (!Model.Tareas.Any())
                {
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-check2-all display-6 d-block mb-2"></i>
                        <p>No hay tareas aún.</p>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Tareas" asp-action="Create" asp-route-proyectoId="@Model.Id"
                               class="btn btn-sm btn-primary">Agregar primera tarea</a>
                        }
                    </div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var tarea in Model.Tareas.OrderBy(t => t.Estado))
                        {
                            var priColor = tarea.Prioridad switch
                            {
                                MiniJira.Models.Prioridad.Critica => "danger",
                                MiniJira.Models.Prioridad.Alta => "warning",
                                MiniJira.Models.Prioridad.Media => "info",
                                _ => "secondary"
                            };
                            var estadoIcon = tarea.Estado switch
                            {
                                MiniJira.Models.EstadoTarea.Completada => "bi-check-circle-fill text-success",
                                MiniJira.Models.EstadoTarea.EnProgreso => "bi-play-circle-fill text-primary",
                                MiniJira.Models.EstadoTarea.Bloqueada => "bi-x-circle-fill text-danger",
                                _ => "bi-circle text-muted"
                            };
                            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi @estadoIcon fs-5"></i>
                                    <div>
                                        <div class="fw-semibold">@tarea.Titulo</div>
                                        @if (tarea.FechaLimite.HasValue)
                                        {
                                            <small class="text-muted">
                                                <i class="bi bi-calendar2-event me-1"></i>
                                                Límite: @tarea.FechaLimite.Value.ToString("dd/MM/yyyy")
                                            </small>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-@priColor-subtle text-@priColor border border-@priColor-subtle">
                                        @tarea.Prioridad
                                    </span>
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <a asp-controller="Tareas" asp-action="Edit" asp-route-id="@tarea.Id"
                                           class="btn btn-outline-secondary btn-sm py-0">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-controller="Tareas" asp-action="Delete" asp-route-id="@tarea.Id"
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('¿Eliminar esta tarea?')">
                                            <button type="submit" class="btn btn-outline-danger btn-sm py-0">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
