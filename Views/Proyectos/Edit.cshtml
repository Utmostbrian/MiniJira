@model MiniJira.Models.Proyecto
@{
    ViewData["Title"] = "Editar Proyecto";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-secondary text-white">
                <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Editar Proyecto</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="FechaCreacion" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                        <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Estado" class="form-label fw-semibold"></label>
                        <select asp-for="Estado"
                                asp-items="Html.GetEnumSelectList<MiniJira.Models.EstadoProyecto>()"
                                class="form-select"></select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-secondary px-4">
                            <i class="bi bi-check-circle me-1"></i>Guardar Cambios
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
