@model MiniJira.Models.Tarea
@{
    ViewData["Title"] = "Editar Tarea";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-secondary text-white">
                <h4 class="mb-0">
                    <i class="bi bi-pencil-square me-2"></i>Editar Tarea
                    <small class="fw-normal fs-6 ms-2">— @ViewBag.ProyectoNombre</small>
                </h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ProyectoId" />

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Titulo" class="form-label fw-semibold"></label>
                        <input asp-for="Titulo" class="form-control" />
                        <span asp-validation-for="Titulo" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Estado" class="form-label fw-semibold"></label>
                            <select asp-for="Estado"
                                    asp-items="Html.GetEnumSelectList<MiniJira.Models.EstadoTarea>()"
                                    class="form-select"></select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Prioridad" class="form-label fw-semibold"></label>
                            <select asp-for="Prioridad"
                                    asp-items="Html.GetEnumSelectList<MiniJira.Models.Prioridad>()"
                                    class="form-select"></select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="FechaLimite" class="form-label fw-semibold"></label>
                        <input asp-for="FechaLimite" class="form-control" type="date" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-secondary px-4">
                            <i class="bi bi-check-circle me-1"></i>Guardar Cambios
                        </button>
                        <a asp-controller="Proyectos" asp-action="Details" asp-route-id="@Model.ProyectoId"
                           class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
